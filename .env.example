NODE_ENV=development
PORT=3000

# Railway provides this as a single connection string.
# Copy the value from your Railway project → Postgres service → Variables → DATABASE_URL
DATABASE_URL=postgresql://postgres:password@host.railway.app:5432/railway
DATABASE_POOL_MAX=20

# Railway provides this as a single connection string.
# Copy the value from your Railway project → Redis service → Variables → REDIS_URL
REDIS_URL=redis://default:password@host.railway.app:6379

ADMIN_API_KEY_HASH=

API_VERSION=1
CORS_ORIGIN=http://localhost:3001
